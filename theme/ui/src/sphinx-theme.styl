/*** admonitions based on custom-blocks.styl */
.admonition
  padding 1.25rem 1.5rem
  border 1px solid var(--theme-border)
  border-left-width 4px
  border-left-style solid
  margin 1.5rem 0
  border-radius 12px
  background-color var(--theme-admonition-bg)
  backdrop-filter blur(8px)
  border-left-color var(--theme-blockquote-border)
  box-shadow 0 2px 4px -1px rgba(0,0,0,0.03)

  .admonition-title
    font-family $header_font, $header_font_fallback
    font-weight 600
    margin-bottom 0.5rem
    color var(--theme-admonition-title)

  p, li
    color var(--theme-admonition-text)

  &.tip, &.hint
    background-color var(--theme-admonition-tip-bg)
    border-color var(--theme-admonition-tip-border)
    border-left-color var(--theme-admonition-tip-accent)

  &.important, &.note
    background-color var(--theme-admonition-note-bg)
    border-color var(--theme-admonition-note-border)
    border-left-color var(--theme-admonition-note-accent)

  &.warning, &.caution
    background-color var(--theme-admonition-warning-bg)
    border-color var(--theme-admonition-warning-border)
    border-left-color var(--theme-admonition-warning-accent)
    color var(--theme-admonition-title)

    .custom-block-title
      color var(--theme-admonition-title)

    a
      color var(--theme-text)

  &.danger, &.error
    background-color var(--theme-admonition-danger-bg)
    border-color var(--theme-admonition-danger-border)
    border-left-color var(--theme-admonition-danger-accent)
    color var(--theme-admonition-title)

    .custom-block-title
      color var(--theme-admonition-title)

    a
      color var(--theme-text)

blockquote
  margin-left -0.4rem
