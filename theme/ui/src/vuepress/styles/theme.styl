@require './config'
@require './nprogress'
@require './code'
@require './custom-blocks'
@require './arrow'
@require './wrapper'
@require './toc'
@require './codeNbsphinx.styl'

:root
  --theme-accent: $accentColor
  --theme-link: $accentColor
  --theme-bg: $pageBgColor
  --theme-surface: #ffffff
  --theme-surface-muted: #f3f4f6
  --theme-surface-subtle: #f8fafc
  --theme-text: $textColor
  --theme-text-muted: $mutedTextColor
  --theme-text-soft: #6b7280
  --theme-border: $borderColor
  --theme-navbar-bg: rgba(255, 255, 255, 0.85)
  --theme-sidebar-heading: #1f1f1f
  --theme-sidebar-caption: #999999
  --theme-sidebar-caption-hover-bg: #e5e7eb
  --theme-sidebar-current-bg: #eff6ff
  --theme-sidebar-hover-bg: #f3f4f6
  --theme-sidebar-panel-bg: #ffffff
  --theme-sidebar-footer-bg: rgba(248, 250, 252, 0.96)
  --theme-blockquote-border: #9ca3af
  --theme-admonition-bg: rgba(243, 244, 246, 0.88)
  --theme-admonition-tip-bg: rgba(240, 253, 244, 0.88)
  --theme-admonition-note-bg: rgba(239, 246, 255, 0.88)
  --theme-admonition-warning-bg: rgba(254, 252, 232, 0.88)
  --theme-admonition-danger-bg: rgba(254, 242, 242, 0.88)
  --theme-admonition-title: #0F172A
  --theme-admonition-text: $textColor
  --theme-admonition-tip-border: #bbf7d0
  --theme-admonition-tip-accent: #22c55e
  --theme-admonition-note-border: #bfdbfe
  --theme-admonition-note-accent: #3b82f6
  --theme-admonition-warning-border: #fef08a
  --theme-admonition-warning-accent: #eab308
  --theme-admonition-danger-border: #fecaca
  --theme-admonition-danger-accent: #ef4444
  --theme-footer-text: grey
  --theme-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03)

html[data-theme='dark']
  --theme-link: #60A5FA
  --theme-bg: #020617
  --theme-surface: #0F172A
  --theme-surface-muted: #1E293B
  --theme-surface-subtle: #0B1120
  --theme-text: #F8FAFC
  --theme-text-muted: #94A3B8
  --theme-text-soft: #64748B
  --theme-border: #1E293B
  --theme-navbar-bg: rgba(2, 6, 23, 0.85)
  --theme-sidebar-heading: #F8FAFC
  --theme-sidebar-caption: #94A3B8
  --theme-sidebar-caption-hover-bg: rgba(148, 163, 184, 0.16)
  --theme-sidebar-current-bg: rgba(59, 130, 246, 0.18)
  --theme-sidebar-hover-bg: rgba(148, 163, 184, 0.12)
  --theme-sidebar-panel-bg: #0B1120
  --theme-sidebar-footer-bg: rgba(11, 17, 32, 0.96)
  --theme-blockquote-border: #475569
  --theme-admonition-bg: rgba(15, 23, 42, 0.92)
  --theme-admonition-tip-bg: rgba(20, 83, 45, 0.24)
  --theme-admonition-note-bg: rgba(30, 64, 175, 0.22)
  --theme-admonition-warning-bg: rgba(133, 77, 14, 0.22)
  --theme-admonition-danger-bg: rgba(153, 27, 27, 0.22)
  --theme-admonition-title: #E2E8F0
  --theme-admonition-text: #DBEAFE
  --theme-admonition-tip-border: #14532D
  --theme-admonition-tip-accent: #22C55E
  --theme-admonition-note-border: #1D4ED8
  --theme-admonition-note-accent: #60A5FA
  --theme-admonition-warning-border: #A16207
  --theme-admonition-warning-accent: #F59E0B
  --theme-admonition-danger-border: #B91C1C
  --theme-admonition-danger-accent: #F87171
  --theme-footer-text: #64748B
  --theme-shadow: 0 12px 28px -16px rgba(2, 6, 23, 0.85)

html, body
  padding 0
  margin 0
  font-family $average_font, $average_font_fallback
  font-weight $average_font_weight
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale
  background-color var(--theme-bg)

body
  color var(--theme-text)

button, input, select, textarea
  font-family inherit

input, select, textarea
  color var(--theme-text)


.page
  padding-left $sidebarWidth
  min-height 100vh
  background-color var(--theme-bg)
  box-sizing border-box

.navbar
  position fixed
  z-index 20
  top 1rem
  left 1rem
  right 1rem
  height $navbarHeight
  background-color var(--theme-navbar-bg)
  backdrop-filter blur(12px)
  -webkit-backdrop-filter blur(12px)
  box-sizing border-box
  border 1px solid var(--theme-border)
  border-radius 12px
  box-shadow var(--theme-shadow)
  transition all 0.3s ease

.sidebar-mask
  position fixed
  z-index 9
  top 0
  left 0
  width 100vw
  height 100vh
  display none

.sidebar
  font-size 15px
  background-color transparent
  width $sidebarWidth
  position fixed
  z-index 10
  margin 0
  top ($navbarHeight + 2rem)
  left 0
  bottom 0
  box-sizing border-box
  border-right 1px solid var(--theme-border)
  overflow-y auto
  transition all 0.3s ease

.content:not(.custom)
  @extend $wrapper

p.demo
  padding 1rem 1.5rem
  border 1px solid var(--theme-border)
  border-radius 4px
  background-color var(--theme-surface)

img
  max-width 100%

.content.custom
  padding 0
  margin 0

  img
    max-width 100%

a
  font-weight 500
  color var(--theme-link)
  text-decoration none
  transition color 0.2s ease

p a code
  font-weight 400
  color var(--theme-link)

kbd
  background var(--theme-surface-muted)
  border solid 0.15rem var(--theme-border)
  border-bottom solid 0.25rem var(--theme-border)
  border-radius 0.15rem
  padding 0 0.15em

blockquote
  font-size 1.1rem
  color var(--theme-text-soft)
  border-left .25rem solid var(--theme-blockquote-border)
  background-color var(--theme-surface-muted)
  margin-left 0
  padding 1rem 1.5rem
  border-radius 0 8px 8px 0

//ul, ol
//  padding-left 1.2em

strong
  font-family $bold_font, $average_font_fallback
  font-weight $bold_font_weight

h1, h2, h3, h4, h5, h6
  font-family $header_font, $header_font_fallback
  font-weight $header_font_weight
  line-height 1.25

  .content:not(.custom) > &
    margin-top (0.5rem - $navbarHeight)
    padding-top ($navbarHeight + 1rem)
    margin-bottom 0

    &:first-child
      margin-top -1.5rem
      margin-bottom 1rem

      + p, + pre, + .custom-block
        margin-top 2rem

  &:hover .header-anchor
    opacity: 1

h1
  font-size 2.2rem
  letter-spacing -0.02em

h2
  font-size 1.65rem
  padding-bottom .3rem
  border-bottom 1px solid var(--theme-border)
  letter-spacing -0.01em

h3
  font-size 1.35rem
  letter-spacing -0.01em

a.header-anchor
  font-size 0.85em
  float left
  margin-left -0.87em
  padding-right 0.23em
  margin-top 0.125em
  opacity 0

  &:hover
    text-decoration none

code, kbd, .line-number
  font-family 'JetBrains Mono', 'Fira Code', source-code-pro, Menlo, Monaco, Consolas, "Courier New", monospace


hr
  border 0
  border-top 1px solid var(--theme-border)

table
  border-collapse collapse
  margin 1.5rem 0
  display: block
  overflow-x: auto
  border-radius 8px
  border 1px solid var(--theme-border)
  box-shadow 0 1px 2px rgba(0,0,0,0.05)
  background-color var(--theme-surface)

tr
  border-top 1px solid var(--theme-border)

  &:nth-child(2n)
    background-color var(--theme-surface-subtle)

th, td
  border 1px solid var(--theme-border)
  padding .75em 1em

th
  background-color var(--theme-surface-muted)
  color var(--theme-text)

.custom-layout
  padding-top $navbarHeight

.theme-container
  &.sidebar-open
    .sidebar-mask
      display: block

  &.no-navbar
    .content:not(.custom) > h1, h2, h3, h4, h5, h6
      margin-top 1.5rem
      padding-top 0

    .sidebar
      top 0

    .custom-layout
      padding-top 0


@media (min-width: ($MQMobile + 1px))
  .theme-container.no-sidebar
    .sidebar
      display none

    .page
      padding-left 0

@require './mobile.styl'


@-webkit-keyframes fade-in {
  0% {
    opacity: 0.1;
  }
  100% {
    opacity: 1;
  }
}

@-moz-keyframes fade-in {
  0% {
    opacity: 0.1;
  }
  100% {
    opacity: 1;
  }
}

@-o-keyframes fade-in {
  0% {
    opacity: 0.1;
  }
  100% {
    opacity: 1;
  }
}

@keyframes fade-in {
  0% {
    opacity: 0.1;
  }
  100% {
    opacity: 1;
  }
}

#app, body, html {
  height: 100%;
}

body {
  overflow-x: hidden;
  margin: 0;
  background-color: #F8FAFC;
}

body, html {
  height: 100%;
}

body {
  overflow-y: scroll;
}

#app {
  display: flex;
  flex-direction: column;
  height: 100%;
  justify-content: space-between;
}

.content {
  position: relative;
  max-width: 896px;
  margin: calc(2rem + 72px) auto 2rem;
  padding: 48px 60px;
  background-color: var(--theme-surface);
  border-radius: 8px;
  box-shadow: var(--theme-shadow);
  border: 1px solid var(--theme-border);
}

.content.api > a:first-of-type > h2 {
  margin-top: 0;
  padding-top: 0;
}

.content.api ul {
  padding-left: 1.25em;
  line-height: 1.4em;
}

.content.api ul ul,
.content.api ul p:not(.tip) {
  padding-bottom: 0;
  margin: 1.2em 0;
}

.content a.button {
  font-size: 0.9em;
  font-weight: 500;
  color: #fff;
  background-color: var(--theme-accent);
  border-radius: 6px;
  transition: all 0.25s ease;
  margin: 0.2em 0;
  width: 200px;
  text-align: center;
  padding: 12px 24px;
  display: inline-block;
  vertical-align: middle;
}
.content a.button:hover {
  filter: brightness(0.95);
  transform: translateY(-1px);
  box-shadow: var(--theme-shadow);
  text-decoration: none;
}

.content img {
  max-width: 100%;
}

.content span.light {
  color: var(--theme-text-muted);
}

.content span.info {
  font-size: 0.85em;
  display: inline-block;
  vertical-align: middle;
  width: 280px;
  margin-left: 20px;
}

.content h2:before,
.content h3:before {
  content: "";
  display: block;
  visibility: hidden;
}

.content h2 {
  margin: 45px 0 0.8em;
  padding-bottom: 0.7em;
  border-bottom: 1px solid var(--theme-border);
}

.content h3 {
  margin: 52px 0 1.2em;
  line-height: 1.2;
  position: relative;
}

.content h3 > a:before {
  content: "#";
  color: var(--theme-link);
  position: absolute;
  left: -0.7em;
  margin-top: -0.05em;
  padding-right: 0.5em;
  font-size: 1.2em;
  line-height: 1;
  font-weight: bold;
}

.content figure {
  margin: 1.2em 0;
}


.content blockquote {
  margin: 2em 0;
  padding-left: 20px;
  border-left: 4px solid var(--theme-link);
}

.content blockquote p {
  font-weight: 600;
  margin-left: 0;
  margin-bottom: 0;
  padding-bottom: 0;
  padding-top: 0;
  margin-top: 0;
}

.content iframe {
  margin: 1em 0;
}

.content > table {
  border-spacing: 0;
  border-collapse: collapse;
  margin: 1.5em 0;
  padding: 0;
  display: block;
  overflow-x: auto;
  border-radius: 8px;
  border: 1px solid var(--theme-border);
  box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  background-color: var(--theme-surface);
}

.content > table td,
.content > table th {
  line-height: 1.5em;
  padding: 0.4em 0.8em;
  border: none;
  border: 1px solid var(--theme-border);
}

.content > table th {
  font-weight: bold;
  text-align: left;
}

.content > table th,
.content > table tr:nth-child(2n) {
  background-color: var(--theme-surface-muted);
}

.content > table th code,
.content > table tr:nth-child(2n) code {
  background-color: var(--theme-surface-subtle);
}

.content p.tip,
.content p.success {
  padding: 12px 24px 12px 30px;
  margin: 2em 0;
  border-left-width: 4px;
  border-left-style: solid;
  background-color: var(--theme-surface-muted);
  position: relative;
  border-bottom-right-radius: 2px;
  border-top-right-radius: 2px;
  color: var(--theme-text);
}

.content p.tip:before,
.content p.success:before {
  position: absolute;
  top: 14px;
  left: -12px;
  color: #fff;
  width: 20px;
  height: 20px;
  border-radius: 100%;
  text-align: center;
  line-height: 20px;
  font-weight: bold;
  font-family: $average_font;
  font-size: 14px;
}

.content p.tip code,
.content p.success code {
  background-color: var(--theme-surface-subtle);
}

.content p.tip em,
.content p.success em {
  color: var(--theme-text);
}

.content p.tip {
  border-left-color: var(--theme-admonition-danger-accent);
  background-color: var(--theme-admonition-danger-bg);
}

.content p.tip:before {
  content: "!";
  background-color: var(--theme-admonition-danger-accent);
}

.content p.success {
  border-left-color: var(--theme-admonition-tip-accent);
  background-color: var(--theme-admonition-tip-bg);
}

.content p.success:before {
  content: "\f00c";
  font-family: FontAwesome;
  background-color: var(--theme-admonition-tip-accent);
}

/* Search Results Styles */
#search-results {
  background: var(--theme-surface-subtle);
  border: 1px solid var(--theme-border);
  border-radius: 12px;
  padding: 32px;
  margin-top: 48px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.02);

  h2 {
    margin-top: 0;
    margin-bottom: 24px;
    font-size: 1.5rem;
    color: var(--theme-text);
    border-bottom: 2px solid var(--theme-border);
    padding-bottom: 12px;
  }

  .search {
    list-style: none;
    padding: 0;
    margin: 0;

    li {
      margin-bottom: 24px;
      padding-bottom: 24px;
      border-bottom: 1px dashed var(--theme-border);
      transition: transform 0.2s ease, opacity 0.2s ease;

      &:last-child {
        border-bottom: none;
        padding-bottom: 0;
        margin-bottom: 0;
      }

      &:hover {
        opacity: 0.95;
      }

      > a {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--theme-link);
        display: block;
        margin-bottom: 8px;
        text-decoration: none;
        letter-spacing: -0.01em;

        &:hover {
          text-decoration: underline;
        }
      }

      .context {
        font-size: 0.95rem;
        color: var(--theme-text-soft);
        line-height: 1.6;
        display: block;
        background: var(--theme-surface);
        padding: 16px;
        border-radius: 8px;
        border: 1px solid var(--theme-border);
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.01);
      }
      
      .highlighted {
        background-color: var(--theme-sidebar-current-bg);
        color: var(--theme-link);
        font-weight: bold;
        padding: 0 4px;
        border-radius: 4px;
      }
    }
  }
}

chat-ai
  display block
  width 100%

/* Vue hydrates <chat-ai> into a .chat-container element, so target the rendered node. */
.content > .chat-container + h1,
.content > .chat-container + h2 {
  margin-top: 1.5rem !important;
  padding-top: 0 !important;
}
