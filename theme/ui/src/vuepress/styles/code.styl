@require './config'

.content
  code
    color lighten($textColor, 20%)
    padding 0.25rem 0.5rem
    margin 0
    font-size 0.85em
    //background-color rgba(27, 31, 35, 0.05)
    border-radius 3px

.content
  pre, pre[class*="language-"]
    line-height 1.5
    padding 3rem 1.5rem 1.25rem
    margin 1.5rem 0
    background-color $codeBgColor
    border-radius 12px
    border 1px solid rgba(255, 255, 255, 0.1)
    box-shadow 0 12px 24px -8px rgba(0, 0, 0, 0.4)
    overflow auto

    code
      color #fff
      padding 0
      background-color transparent
      border-radius 0

div[class*="language-"],
div.highlight
  position relative
  background-color $codeBgColor
  border-radius 12px
  box-shadow 0 12px 24px -8px rgba(0, 0, 0, 0.4)
  border 1px solid rgba(255, 255, 255, 0.1)
  margin 1.5rem 0

  pre
    margin 0 !important
    background-color transparent !important
    border none !important
    box-shadow none !important
    color #e2e8f0 !important

  pre code,
  pre span
    color #e2e8f0

  &::after
    content ''
    position absolute
    top 14px
    left 16px
    width 12px
    height 12px
    border-radius 50%
    background #ff5f56
    box-shadow 20px 0 0 #ffbd2e, 40px 0 0 #27c93f
    z-index 2

// Pygments dark theme syntax highlighting (for Sphinx-generated code)
div.highlight
  // Keywords (import, def, class, return, etc.)
  .k, .kn, .kd, .kp, .kr, .kt, .kc
    color #c084fc
  // Strings
  .s, .s1, .s2, .sa, .sb, .sc, .sd, .se, .sh, .si, .sr, .ss, .sx
    color #86efac
  // Names / identifiers
  .n, .na, .nb, .nc, .nd, .ne, .nf, .ni, .nl, .nn, .no, .nt, .nv, .nx
    color #e2e8f0
  // Built-in names
  .nb
    color #67e8f9
  // Function/class names
  .nf, .nc
    color #7dd3fc
  // Operators
  .o, .ow
    color #fbbf24
  // Punctuation
  .p
    color #cbd5e1
  // Comments
  .c, .c1, .cm, .cs, .ch, .cp, .cpf
    color #64748b
    font-style italic
  // Numbers
  .m, .mf, .mh, .mi, .mo, .mb, .il
    color #fca5a5
  // Decorators
  .nd
    color #c084fc
  // Generic
  .g, .gd, .ge, .gh, .gi, .go, .gp, .gs, .gt, .gu
    color #e2e8f0
  // Output (for console/shell)
  .go
    color #94a3b8
  // Error
  .err
    color #fca5a5
  // Whitespace
  .w
    color #334155

.has-copy-btn
  position relative

.copy-button
  position absolute
  top 0.8rem
  right 0.8rem
  background rgba(255, 255, 255, 0.1)
  color #fff
  border 1px solid rgba(255, 255, 255, 0.1)
  border-radius 8px
  padding 0.4rem 0.8rem
  font-size 0.75rem
  cursor pointer
  opacity 0
  transition all 0.25s cubic-bezier(0.4, 0, 0.2, 1)
  z-index 5
  backdrop-filter blur(4px)

div[class*="language-"]:hover .copy-button,
.highlight:hover .copy-button
  opacity 1

.copy-button:hover
  background rgba(255, 255, 255, 0.2)
  transform translateY(-1px)
  box-shadow 0 4px 6px -1px rgba(0, 0, 0, 0.1)

.copy-button:active
  transform scale(0.95)

  .highlight-lines
    user-select none
    padding-top 1.3rem
    position absolute
    top 0
    left 0
    width 100%
    line-height 1.4

    .highlighted
      background-color rgba(0, 0, 0, 66%)

  pre, pre[class*="language-"]
    background transparent
    position relative
    z-index 1

  &::before
    position absolute
    z-index 3
    top 0.8em
    right 1em
    font-size 0.75rem
    color rgba(255, 255, 255, 0.4)

  &:not(.line-numbers-mode)
    .line-numbers-wrapper
      display none

  &.line-numbers-mode
    .highlight-lines .highlighted
      position relative

      &:before
        content ' '
        position absolute
        z-index 3
        left 0
        top 0
        display block
        width $lineNumbersWrapperWidth
        height 100%
        background-color rgba(0, 0, 0, 66%)

    pre
      padding-left $lineNumbersWrapperWidth + 1 rem
      vertical-align middle

    .line-numbers-wrapper
      position absolute
      top 0
      width $lineNumbersWrapperWidth
      text-align center
      color rgba(255, 255, 255, 0.3)
      padding 1.25rem 0
      line-height 1.4

      br
        user-select none

      .line-number
        position relative
        z-index 4
        user-select none
        font-size 0.85em

    &::after
      content ''
      position absolute
      z-index 2
      top 0
      left 0
      width $lineNumbersWrapperWidth
      height 100%
      border-radius 6px 0 0 6px
      border-right 1px solid rgba(0, 0, 0, 66%)
      background-color $codeBgColor


