@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');

$accentColor = #3B82F6      // Blue 500 - modern CTA
$secondaryColor = #64748B   // Slate 500
$ctaColor = #3B82F6         // CTA
$textColor = #0F172A       // Slate 900
$mutedTextColor = #475569  // Slate 600
$borderColor = #E2E8F0     // Slate 200
$codeBgColor = #020617     // Deep slate for modern code blocks
$pageBgColor = #F8FAFC     // Soft background for the entire page
$arrowBgColor = #94A3B8

// layout
$navbarHeight = 72px       // Taller for modern floating appearance
$sidebarWidth = 18rem
$contentWidth = 896px

// responsive breakpoints
$MQNarrow = 959px
$MQMobile = 719px
$MQMobileNarrow = 419px

// code
$lineNumbersWrapperWidth = 3.5rem

// typography
$light_font = 'Roboto'
$average_font = 'Roboto'
$header_font = 'Roboto'
$bold_font = 'Roboto'

$light_font_weight = 300
$average_font_weight = 400
$header_font_weight = 500
$bold_font_weight = 700

$average_font_fallback = system-ui, -apple-system, 'Segoe UI', Roboto, Arial, 'Helvetica Neue', Helvetica, 'Noto Sans', 'Liberation Sans', sans-serif
$header_font_fallback = system-ui, -apple-system, 'Segoe UI', Roboto, Arial, 'Helvetica Neue', Helvetica, 'Noto Sans', 'Liberation Sans', sans-serif
